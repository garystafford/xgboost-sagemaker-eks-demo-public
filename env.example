# Copy this file to .env and replace the example values for your environment.
# Do not store AWS access keys or other credentials here.

AWS_ACCOUNT_ID=123456789012
AWS_DEFAULT_REGION=us-east-1

EKS_CLUSTER_NAME=my-eks-cluster
EKS_NAMESPACE=ml-inference

IMAGE_REPO_NAME=demo-xgboost-reg-service
MODEL_PACKAGE_GROUP=xgboost-regression-models

CODEBUILD_PROJECT_NAME=xgboost-eks-deploy
CODEBUILD_SERVICE_ROLE_NAME=CodeBuildServiceRole
EVENTBRIDGE_CODEBUILD_ROLE_NAME=EventBridgeCodeBuildRole

DATA_S3_URI=s3://my-sagemaker-bucket/path/to/abalone.csv
EXPERIMENT_NAME=xgboost-eks-experiments
MLFLOW_TRACKING_SERVER_NAME=ml-flow-tracking-demo
MAX_TUNING_JOBS=8
MAX_PARALLEL_TUNING_JOBS=2
